# Backend API URL (interno no Railway, externo em dev)
BACKEND_URL=http://localhost:8080

# Public API URL (usado no frontend via proxy)
# Em dev: /api (usa proxy do Next.js)
# Em prod: https://api-core.theretech.com.br (aponta direto pra API)
NEXT_PUBLIC_API_URL=/api

# App Config
NEXT_PUBLIC_APP_NAME=The Retech Core
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Documentação Redoc URL
NEXT_PUBLIC_DOCS_URL=https://api-core.theretech.com.br/docs

# Railway Production (exemplo)
# BACKEND_URL=http://retech-core:8080 (não usado em prod, só no proxy)
# NEXT_PUBLIC_API_URL=https://api-core.theretech.com.br
# NEXT_PUBLIC_APP_URL=https://core.theretech.com.br
# NEXT_PUBLIC_DOCS_URL=https://api-core.theretech.com.br/docs


# WhatsApp de vendas (OBRIGATORIA) - numero com DDI/DDD, so digitos. Ex: 5511999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=
